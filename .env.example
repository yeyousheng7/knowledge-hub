# MySQL for Docker Compose
MYSQL_DATABASE=knowledge_hub
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=knowledgehub
MYSQL_PASSWORD=knowledgehub
MYSQL_PORT=3306

# Backend for Docker Compose
BACKEND_PORT=8080
APP_INVITE_CODE=dev-invite-code
JWT_SECRET=local-dev-jwt-secret-change-me-at-least-32-bytes
JWT_EXPIRE_SECONDS=86400
# Admin initialization
ADMIN_INIT_ENABLED=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_NICKNAME=admin

# Redis
REDIS_DATABASE=0

# AI configuration placeholders
# AI is disabled by default. 
# When AI_ENABLED=true, set base URL, API key, and model explicitly.
AI_ENABLED=false

AI_CHAT_PROVIDER=deepseek
AI_CHAT_BASE_URL=
AI_CHAT_API_KEY=
AI_CHAT_MODEL=

AI_EMBEDDING_PROVIDER=
AI_EMBEDDING_BASE_URL=
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=
