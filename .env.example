# MySQL for Docker Compose
MYSQL_DATABASE=knowledge_hub
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=knowledgehub
MYSQL_PASSWORD=knowledgehub
MYSQL_PORT=3306

# Backend for Docker Compose
BACKEND_PORT=8080
APP_INVITE_CODE=dev-invite-code
JWT_SECRET=local-dev-jwt-secret-change-me-at-least-32-bytes
JWT_EXPIRE_SECONDS=86400
# Admin initialization
ADMIN_INIT_ENABLED=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_NICKNAME=admin

# Redis
REDIS_PORT=6379
REDIS_DATABASE=0

# AI feature switches
# Keep all values below as-is when AI is not needed.
AI_ENABLED=false
AI_RAG_ENABLED=false
AI_AGENT_ENABLED=false

# Chat model (required by both RAG and Agent)
SPRING_AI_MODEL_CHAT=none
AI_CHAT_PROVIDER=deepseek
AI_CHAT_BASE_URL=
AI_CHAT_API_KEY=
AI_CHAT_MODEL=

# Embedding model and Redis VectorStore (required by RAG only)
SPRING_AI_MODEL_EMBEDDING=none
AI_EMBEDDING_BASE_URL=https://api.siliconflow.cn
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
AI_INDEX_VECTOR_STORE=none
AI_VECTORSTORE_REDIS_INITIALIZE_SCHEMA=false

# Agent memory (optional)
AI_AGENT_MEMORY_ENABLED=false

# Advanced AI tuning. Defaults are defined in application.yml; uncomment only
# when the provider or workload requires different values.
# AI_EMBEDDING_DIMENSIONS=1024
# AI_INDEX_CHUNK_SIZE=1024
# AI_INDEX_CHUNK_OVERLAP=50
# AI_INDEX_TOP_K=3
# AI_INDEX_VECTOR_INDEX_NAME=kh_note_chunks
# AI_VECTORSTORE_REDIS_PREFIX=kh:ai:note:chunk:
# AI_AGENT_MEMORY_MAX_MESSAGES=20
# AI_AGENT_OPERATION_TTL_MINUTES=30

# Frontend for Docker Compose
FRONTEND_PORT=3000
